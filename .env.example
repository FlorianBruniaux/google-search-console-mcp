# -- Service Account (recommended for automation and CI) ---------------------
# Path to your GCP service account JSON key file.
# The service account must have Owner access on the GSC property
# (Full access is not enough for the Indexing API).
GSC_SERVICE_ACCOUNT_PATH=/absolute/path/to/service-account.json

# Set to true to skip the OAuth fallback when using a service account.
# Prevents an interactive browser flow from launching unexpectedly.
GSC_SKIP_OAUTH=true

# -- OAuth Desktop (alternative to service account) --------------------------
# Path to the OAuth Desktop client JSON downloaded from GCP Console.
# Only needed if you are NOT using a service account.
# GSC_CREDENTIALS_PATH=/absolute/path/to/client_secret.json

# -- Google Analytics 4 ------------------------------------------------------
# Numeric GA4 property ID (find it in GA4 > Admin > Property Settings).
# Required for ga4_* and cross-platform tools. Leave unset for GSC-only use.
GA4_PROPERTY_ID=123456789

# -- Chrome UX Report (CrUX) -------------------------------------------------
# Google API key with the Chrome UX Report API enabled in your GCP project.
# This is a plain API key, NOT a service account. Required for crux_* tools.
# Create one at: GCP Console > APIs and Services > Credentials > Create API key
CRUX_API_KEY=AIzaSy...
